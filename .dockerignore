# Version control
.git
.gitignore

# Python caches / build artifacts
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
.venv/

# Local databases (never bake into the image — use the data volume)
*.db
*.sqlite
*.sqlite3

# Secrets / local env
.env
.env.local
.env.*.local

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# Most docs are not needed at runtime, but VERSION_HISTORY.md is rendered by
# the in-app /docs/version-history page.
docs/*
!docs/VERSION_HISTORY.md
README.md

# Logs
*.log
logs/

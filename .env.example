# Copy to .env and fill in before deploying:  cp .env.example .env
#
# Required. Signs session cookies — MUST be a long random value in production.
# Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Optional overrides (defaults shown).
# Inactivity timeout for normal sessions, in minutes.
SESSION_TIMEOUT_MINUTES=480
# Max lifetime for "remember this terminal" sessions, in days.
SESSION_MAX_AGE_DAYS=30
